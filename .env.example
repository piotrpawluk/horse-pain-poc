# Gemini AI Studio API key — get one at https://aistudio.google.com/app/apikey
#
# WARNING: AI Studio has no EU data residency.
#
#   Acceptable for: Read My Ears (CC-BY-4.0, anonymized, public dataset).
#   NOT acceptable for: field-collected clips with identifiable riders /
#                       handlers / horses owners — that's personal data
#                       under GDPR Art. 4. For field data, switch to
#                       Vertex AI europe-west4 instead. See
#                       docs/gemini-integration.md for the migration note.
#
# Copy this file to .env (gitignored) and fill in your key:
#   cp .env.example .env
#   # then edit .env to set GEMINI_API_KEY=...
GEMINI_API_KEY=
