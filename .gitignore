# Fetched by setup.sh (~500 MB+) — not versioned
.venv/
data/
checkpoints/
outputs/
vendor/

# Notebooks: only source files are versioned; executed copies are not
notebooks/*.executed.ipynb
*.ipynb_checkpoints/

# Standard
.DS_Store
*.swp
__pycache__/
*.pyc

# Secrets / API keys (Gemini, etc.) — never commit
.env
